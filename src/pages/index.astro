---
import BlogCard from "../components/BlogCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects, statConfig } from "../data/site";
import { getBlogPosts } from "../lib/blog";
import { fetchGithubPublicRepoCount, fetchGithubStars } from "../lib/github";

const [featuredProjects, publicProjectCount, posts] = await Promise.all([
  Promise.all(
    projects.map(async (project) => ({
      ...project,
      stars: await fetchGithubStars(project.repo, project.stars),
    })),
  ),
  fetchGithubPublicRepoCount(statConfig.githubUsername, statConfig.projectFallbackCount),
  getBlogPosts(),
]);

const stats = [
  { value: `${publicProjectCount}+`, label: "Projects" },
  { value: `${posts.length}+`, label: "Blog Posts" },
  { value: `${statConfig.yearsOfCode}+`, label: "Years of Code" },
];

const digitSegments: Record<string, string[]> = {
  "0": ["a", "b", "c", "d", "e", "f"],
  "1": ["b", "c"],
  "2": ["a", "b", "g", "e", "d"],
  "3": ["a", "b", "c", "d", "g"],
  "4": ["f", "g", "b", "c"],
  "5": ["a", "f", "g", "c", "d"],
  "6": ["a", "f", "g", "e", "c", "d"],
  "7": ["a", "b", "c"],
  "8": ["a", "b", "c", "d", "e", "f", "g"],
  "9": ["a", "b", "c", "d", "f", "g"],
};

const digitSegmentNames = ["a", "b", "c", "d", "e", "f", "g"];

const smokeParticles = Array.from({ length: 42 }, (_, index) => {
  const side = index % 2 === 0 ? -1 : 1;
  const size = [0.18, 0.26, 0.22, 0.3, 0.2, 0.34, 0.24][index % 7];
  const startX = ((index % 9) - 4) * 0.12;
  const rise = [12.5, 15.8, 18.2, 14.6, 20.5, 16.9, 22][index % 7] + Math.floor(index / 7) * 0.3;
  const drift = side * (1.2 + (index % 6) * 0.55);
  const delay = (index % 14) * 58 + Math.floor(index / 14) * 42;

  return `--smoke-size:${size}rem;--smoke-x:${startX}rem;--smoke-rise:${rise}rem;--smoke-drift:${drift}rem;--smoke-delay:${delay}ms;`;
});
---

<BaseLayout
  title="kaiwood — Developer, blogger, builder"
  description="Developer self-marketing page for kaiwood: projects, writing, and development notes."
  currentPath="/"
>
  <section class="container hero">
    <div class="hero-copy">
      <span class="eyebrow">Developer · Blogger · Builder</span>
      <h1>Hi, I’m <span class="accent">Kai Wood</span>.</h1>
      <p class="lead">I build tools, write about development, and share knowledge with the community.</p>
      <div class="actions">
        <a class="button primary" href="#projects">View Projects →</a>
        <a class="button" href="/blog/">Read Blog →</a>
      </div>
      <div class="socials" aria-label="Social links">
        <a class="social-link" href="https://github.com/kaiwood" aria-label="GitHub">
          <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.69c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.9 1.53 2.35 1.09 2.92.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.57 9.57 0 0 1 12 6.85c.85 0 1.7.11 2.5.33 1.9-1.29 2.74-1.02 2.74-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.93.36.31.68.92.68 1.86v2.75c0 .27.18.58.69.48A10 10 0 0 0 12 2Z" />
          </svg>
        </a>
        <a class="social-link" href="/rss.xml" aria-label="RSS feed">
          <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 11a9 9 0 0 1 9 9" />
            <path d="M4 4a16 16 0 0 1 16 16" />
            <circle cx="5" cy="19" r="1" fill="currentColor" stroke="none" />
          </svg>
        </a>
      </div>
    </div>

    <div class="card code-card" aria-label="Developer profile as code">
      <div class="window-dots" aria-hidden="true"><span></span><span></span><span></span></div>
      <pre><code><span class="code-key">const</span> kaiwood = &#123;
  code: [<span class="code-string">"TypeScript"</span>, <span class="code-string">"Python"</span>, <span class="code-string">"Ruby"</span>],
  passion: <span class="code-string">"Developer experience"</span>,
  building: <span class="code-string">"Tools that make devs faster"</span>
&#125;;

<span class="code-comment">// Maker of things, doer of stuff.</span></code></pre>
    </div>
  </section>

  <section class="container section" id="projects">
    <div class="section-heading">
      <div>
        <h2>Featured Projects</h2>
        <p>Selected tools and experiments from my developer workflow.</p>
      </div>
      <a class="text-link" href="https://github.com/kaiwood?tab=repositories" target="_blank" rel="noreferrer">View all projects →</a>
    </div>

    <div class="project-grid">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="container section" id="about">
    <div class="card about-panel">
      <span class="portrait-laser" data-portrait-laser>
        <img class="portrait" src="/images/avatar.png" alt="Portrait of Kai Wood" loading="lazy" />
        <svg class="portrait-laser-beam" data-portrait-laser-beam aria-hidden="true">
          <path class="portrait-laser-glow" data-portrait-laser-path pathLength="1"></path>
          <path class="portrait-laser-line" data-portrait-laser-path pathLength="1"></path>
        </svg>
        <span class="portrait-smoke" aria-hidden="true">
          {smokeParticles.map((style) => <span style={style}></span>)}
        </span>
      </span>
      <div class="about-copy">
        <h2>About Me</h2>
        <p>I’m a passionate developer who loves creating tools that improve the developer experience.</p>
        <p>When I’m not coding, I’m writing blog posts, exploring new technologies, or gaming.</p>
        <a class="button" href="/#about">More about me →</a>
      </div>
      <div class="stats" aria-label="Developer stats">
        {stats.map((stat) => {
          const digits = stat.value.match(/\d/g) ?? [];
          const displayDigits = digits.length === 1 ? ["0", ...digits] : digits;
          const suffix = stat.value.replace(/[\d\s]/g, "");

          return (
            <div class="stat">
              <strong aria-label={stat.value}>
                <span class="clock-digits" data-target={displayDigits.join("")} aria-hidden="true">
                  {displayDigits.map((digit) => (
                    <span class="clock-digit" data-digit={digit}>
                      {digitSegmentNames.map((segment) => (
                        <span
                          class:list={[
                            "clock-segment",
                            `segment-${segment}`,
                            { "is-active": digitSegments[digit]?.includes(segment) },
                          ]}
                          data-segment={segment}
                        ></span>
                      ))}
                    </span>
                  ))}
                </span>
                {suffix && <span class="stat-suffix" aria-hidden="true">{suffix}</span>}
              </strong>
              <span>{stat.label}</span>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="section-heading">
      <div>
        <h2>Latest Posts</h2>
        <p>Thoughts, tutorials, and experiences about development and tools.</p>
      </div>
      <a class="text-link" href="/blog/">Read the blog →</a>
    </div>

    <div class="blog-list">
      {posts.length > 0 ? posts.slice(0, 2).map((post) => <BlogCard post={post} />) : <p class="card empty-state">No published posts yet. Check back soon.</p>}
    </div>
  </section>

  <script>
    const statDigitSegments: Record<string, string[]> = {
      "0": ["a", "b", "c", "d", "e", "f"],
      "1": ["b", "c"],
      "2": ["a", "b", "g", "e", "d"],
      "3": ["a", "b", "c", "d", "g"],
      "4": ["f", "g", "b", "c"],
      "5": ["a", "f", "g", "c", "d"],
      "6": ["a", "f", "g", "e", "c", "d"],
      "7": ["a", "b", "c"],
      "8": ["a", "b", "c", "d", "e", "f", "g"],
      "9": ["a", "b", "c", "d", "f", "g"],
    };

    const reduceStatMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const renderStatDigit = (digitEl: HTMLElement, digit: string, shouldFlip: boolean) => {
      if (digitEl.dataset.digit === digit) return;

      const applyDigit = () => {
        const activeSegments = new Set(statDigitSegments[digit] ?? []);

        digitEl.dataset.digit = digit;
        digitEl.querySelectorAll<HTMLElement>("[data-segment]").forEach((segmentEl) => {
          segmentEl.classList.toggle("is-active", activeSegments.has(segmentEl.dataset.segment ?? ""));
        });
      };

      if (!shouldFlip || reduceStatMotion) {
        applyDigit();
        return;
      }

      digitEl.classList.remove("is-flipping");
      void digitEl.offsetWidth;
      digitEl.classList.add("is-flipping");
      window.setTimeout(applyDigit, 85);
      window.setTimeout(() => digitEl.classList.remove("is-flipping"), 180);
    };

    const renderStatValue = (display: HTMLElement, value: number, shouldFlip: boolean) => {
      const target = display.dataset.target ?? "0";
      const digits = String(value).padStart(target.length, "0").slice(-target.length).split("");
      const digitEls = display.querySelectorAll<HTMLElement>(".clock-digit");

      digitEls.forEach((digitEl, index) => renderStatDigit(digitEl, digits[index] ?? "0", shouldFlip));
    };

    const animateStat = (display: HTMLElement) => {
      const target = Number(display.dataset.target ?? 0);
      if (!Number.isFinite(target)) return;

      if (reduceStatMotion) {
        renderStatValue(display, target, false);
        return;
      }

      let current = 0;
      const delay = Math.max(42, Math.min(90, 1450 / Math.max(target, 1)));

      renderStatValue(display, current, false);

      if (target <= 0) return;

      const tick = () => {
        current += 1;
        renderStatValue(display, current, true);

        if (current < target) {
          window.setTimeout(tick, delay);
        }
      };

      window.setTimeout(tick, 220);
    };

    const statDisplays = document.querySelectorAll<HTMLElement>(".clock-digits[data-target]");

    if ("IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            animateStat(entry.target as HTMLElement);
            observer.unobserve(entry.target);
          });
        },
        { threshold: 0.45 },
      );

      statDisplays.forEach((display) => observer.observe(display));
    } else {
      statDisplays.forEach(animateStat);
    }
  </script>
</BaseLayout>
