---
interface Project {
  name: string;
  description: string;
  tags: string[];
  stars: number;
  icon: string;
  logo?: string;
  accent?: string;
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="card project-card">
  <div class={`project-icon ${project.accent ?? ""}`} aria-hidden="true">
    {project.logo ? <img src={project.logo} alt="" loading="lazy" /> : project.icon}
  </div>
  <div class="stack">
    <h3>{project.name}</h3>
    <p>{project.description}</p>
  </div>
  <footer>
    <div class="tag-list">
      {project.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
    <span class="stars">☆ {project.stars}</span>
  </footer>
</article>
