---
import type { BlogPost } from "../lib/blog";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const postUrl = `/blog/${post.id}/`;
const formattedDate = post.data.pubDate.toLocaleDateString("en", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
const searchText = [post.data.title, post.data.description, post.data.category, ...post.data.tags].join(" ").toLowerCase();
---

<a
  class="card post-card"
  href={postUrl}
  data-post-card
  data-category={post.data.category}
  data-search={searchText}
>
  <time class="post-date" datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
  <div class="post-content">
    <h3>{post.data.title}</h3>
    <p>{post.data.description}</p>
    <div class="post-meta">
      <span class="tag">{post.data.category}</span>
      <span class="read-time">{post.data.readTime}</span>
      {post.data.draft && <span class="tag">Draft</span>}
    </div>
  </div>
  <div class="post-icon" aria-hidden="true">{post.data.icon}</div>
</a>
