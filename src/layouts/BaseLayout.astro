---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = "kaiwood — Developer, blogger, builder",
  description = "Developer self-marketing page and blog for tools, projects, and development notes.",
  currentPath = Astro.url.pathname,
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="kaiwood Blog" href={new URL("/rss.xml", Astro.site ?? Astro.url)} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const preferred = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        document.documentElement.dataset.theme = stored || preferred;
      })();
    </script>
  </head>
  <body>
    <div class="site-shell">
      <SiteHeader currentPath={currentPath} />
      <main>
        <slot />
      </main>
      <SiteFooter />
    </div>

    <script>
      const themeToggle = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");

      themeToggle?.addEventListener("click", () => {
        const current = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
        const next = current === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("theme", next);
      });

      const portraitLaser = document.querySelector<HTMLElement>("[data-portrait-laser]");

      if (portraitLaser) {
        const portrait = portraitLaser.querySelector<HTMLElement>(".portrait");
        const laserBeam = portraitLaser.querySelector<SVGSVGElement>("[data-portrait-laser-beam]");
        const laserPaths = portraitLaser.querySelectorAll<SVGPathElement>("[data-portrait-laser-path]");
        let lastScrollY = window.scrollY;
        let wasInTriggerZone = false;
        let hasCheckedInitialPosition = false;
        let hasPlayedLaser = false;
        let ticking = false;
        let allowStationaryTrigger = false;
        let laserTimer: number | undefined;

        const syncLaserPath = () => {
          if (!portrait || !laserBeam || laserPaths.length === 0) return;

          const { width, height } = portrait.getBoundingClientRect();
          const borderRadius = Number.parseFloat(getComputedStyle(portrait).borderTopLeftRadius) || 0;
          const inset = 0.5;
          const left = inset;
          const top = inset;
          const right = Math.max(left, width - inset);
          const bottom = Math.max(top, height - inset);
          const radius = Math.max(0, Math.min(borderRadius - inset, (right - left) / 2, (bottom - top) / 2));
          const d = [
            `M ${left + radius} ${top}`,
            `H ${right - radius}`,
          ].join(" ");

          portraitLaser.style.setProperty("--laser-end-x", `${right - radius}px`);
          portraitLaser.style.setProperty("--laser-end-y", `${top}px`);
          laserBeam.setAttribute("viewBox", `0 0 ${width} ${height}`);

          laserPaths.forEach((path) => {
            path.setAttribute("d", d);
          });
        };

        const stopLaser = () => {
          portraitLaser.classList.remove("is-laser-active");
          window.clearTimeout(laserTimer);
        };

        const playLaser = () => {
          if (hasPlayedLaser || portraitLaser.classList.contains("is-laser-active")) return;
          hasPlayedLaser = true;
          syncLaserPath();
          portraitLaser.classList.add("is-laser-active");
          laserTimer = window.setTimeout(stopLaser, 4300);
        };

        const updateLaserTrigger = () => {
          const currentScrollY = window.scrollY;
          const scrollingDown = currentScrollY > lastScrollY;
          const rect = portraitLaser.getBoundingClientRect();
          const triggerLine = window.innerHeight * (2 / 3);
          const inTriggerZone = rect.top <= triggerLine && rect.bottom >= triggerLine;

          if ((scrollingDown || allowStationaryTrigger || !hasCheckedInitialPosition) && inTriggerZone && !wasInTriggerZone) {
            playLaser();
          }

          hasCheckedInitialPosition = true;
          wasInTriggerZone = inTriggerZone;
          lastScrollY = currentScrollY;
          ticking = false;
          allowStationaryTrigger = false;
        };

        const requestLaserUpdate = (allowStationary = false) => {
          allowStationaryTrigger = allowStationaryTrigger || allowStationary;
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(updateLaserTrigger);
        };

        const requestInitialLaserUpdate = () => {
          requestLaserUpdate(true);
          window.setTimeout(() => requestLaserUpdate(true), 120);
        };

        syncLaserPath();
        window.addEventListener("scroll", () => requestLaserUpdate(), { passive: true });
        window.addEventListener("load", requestInitialLaserUpdate);
        window.addEventListener("pageshow", requestInitialLaserUpdate);
        window.addEventListener("resize", () => {
          syncLaserPath();
          requestLaserUpdate(true);
        });
        requestInitialLaserUpdate();
      }
    </script>
  </body>
</html>
